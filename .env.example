# Bu fayl namuna sifatida git'ga qo'shiladi. Haqiqiy qiymatlarni .env faylga yozing!
# Yangi SECRET_KEY yaratish:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Production'da (Railway) qo'shimcha:
#   ALLOWED_HOSTS=sizning-loyiha.up.railway.app
#   CSRF_TRUSTED_ORIGINS=https://sizning-loyiha.up.railway.app
CSRF_TRUSTED_ORIGINS=

MONGODB_URI=mongodb://localhost:27017
MONGODB_NAME=url_shortener_db

TIME_ZONE=Asia/Tashkent
